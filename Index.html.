<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Football Creator Hub</title>
    
    <link rel="stylesheet" href="https://pyscript.net/releases/2024.1.1/core.css">
    <script type="module" src="https://pyscript.net/releases/2024.1.1/core.js"></script>

    <style>
        body { font-family: sans-serif; background: #121212; color: white; padding: 20px; text-align: center; }
        .box { background: #1e1e1e; padding: 20px; border-radius: 15px; border: 1px solid #333; max-width: 500px; margin: auto; }
        textarea { width: 90%; height: 100px; background: #252525; color: white; border: 1px solid #444; border-radius: 8px; padding: 10px; margin-top: 15px; }
        button { background: #4caf50; color: white; border: none; padding: 12px 25px; border-radius: 8px; cursor: pointer; font-weight: bold; margin-top: 15px; }
        #output { margin-top: 20px; color: #4caf50; font-family: monospace; font-size: 1.2rem; }
    </style>
</head>
<body>

    <div class="box">
        <h2>Football Script Analyzer</h2>
        <p>Paste your match notes or video script below.</p>
        
        <textarea id="txt-input" placeholder="Example: Real Madrid won 3-1 today..."></textarea>
        
        <button py-click="run_analysis">Run Python Logic</button>
        
        <div id="output">Python Status: Ready</div>
    </div>

    <script type="py">
from pyscript import document

def run_analysis(event):
    # 1. Grab the text from the HTML textarea
    user_text = document.querySelector("#txt-input").value
    
    # 2. Python Logic (Word Count)
    words = user_text.split()
    count = len(words)
    
    # 3. Send the result back to the HTML output div
    result_div = document.querySelector("#output")
    result_div.innerText = f"Result: {count} words analyzed by Python!"
    </script>

</body>
</html>
